# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Docker / CI ──────────────────────────────────────────────────────────────
PACKAGE_NAME=vortex
DOCKER_REGISTRY=your-registry
VERSION=latest

# ── Security (required) ───────────────────────────────────────────────────────
JWT_SECRET=change_me
INTERNAL_SECRET=change_me

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local: each service defaults to its own DB (no value needed for local dev)
# Docker: uses MONGO_USER / MONGO_PASSWORD to build the URI
MONGODB_URI=mongodb://localhost:27017/vortex
MONGO_USER=mongo
MONGO_PASSWORD=mongo
MONGO_DB=vortex

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Local: defaults to amqp://127.0.0.1:5672 (no value needed)
# Docker: uses RABBITMQ_USER / RABBITMQ_PASSWORD to build the URL
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq

# ── Stripe (required for payments) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Superadmin seed (run: pnpm auth:seed) ─────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@vortex.local
SUPERADMIN_PASSWORD=change_me_min_8_chars

# ── Email / SMTP (optional — logs to console if unset) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@vortex.local
APP_URL=http://localhost:3000

# ── External services ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Service ports (optional — defaults shown, only set to override) ───────────
# PORT=3000        # gateway
# PORT=3001        # auth-service
# PORT=3002        # product-service
# PORT=3003        # order-service
# PORT=3004        # notification-service
# PORT=3005        # payment-service
