# ── Docker / CI ──────────────────────────────────────────────────────────────
PACKAGE_NAME=vortex
DOCKER_REGISTRY=your-registry
VERSION=latest

# ── Security (required) ───────────────────────────────────────────────────────
JWT_SECRET=change_me
INTERNAL_SECRET=change_me

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Credentials must match MONGO_INITDB_ROOT_USERNAME / PASSWORD in compose.infra.yaml
MONGO_USER=mongo
MONGO_PASSWORD=mongo
MONGO_DB=vortex
# authSource=admin is required when MongoDB is started with root credentials
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/vortex?authSource=admin

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Credentials must match RABBITMQ_DEFAULT_USER / PASS in compose.infra.yaml
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@localhost:5672
# Management UI: http://localhost:15672

# ── Redis ─────────────────────────────────────────────────────────────────────
# compose.infra.yaml maps redis-master → host port 22376 (not 6379)
REDIS_HOST=localhost
REDIS_PORT=22376

# ── Stripe (required for payments) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx

# ── Superadmin seed (run: pnpm auth:seed) ─────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@vortex.local
SUPERADMIN_PASSWORD=change_me_min_8_chars

# ── Email / SMTP (optional — logs to console if unset) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@vortex.local

# ── App / Gateway URL ─────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Internal service URLs (used by gateway and inter-service calls) ───────────
AUTH_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
ACTIVITY_SERVICE_URL=http://localhost:3006
ANALYTICS_SERVICE_URL=http://localhost:3007

# ── Web app ───────────────────────────────────────────────────────────────────
# Used by next.config.ts (server-side rewrite only — NOT exposed to the browser)
GATEWAY_URL=http://localhost:3000

# ── Service ports (optional — defaults shown, only set to override) ───────────
# PORT=3000        # gateway
# PORT=3001        # auth-service
# PORT=3002        # product-service
# PORT=3003        # order-service
# PORT=3004        # notification-service
# PORT=3005        # payment-service
# PORT=3006        # activity-service
# PORT=3007        # analytics-service
# PORT=4000        # web (Next.js)
