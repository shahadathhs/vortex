{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Authentication Service",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check . --ignore-path .prettierignore",
    "format:fix": "prettier --write . --ignore-path .prettierignore",
    "clean": "rimraf dist node_modules",
    "clean:turbo": "rimraf .turbo dist node_modules"
  },
  "dependencies": {
    "@vortex/common": "workspace:*",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.0-beta.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "@systemix/eslint": "^0.4.0",
    "@systemix/typescript": "^0.4.0"
  }
}
