{
  "name": "vortex",
  "version": "1.5.0",
  "private": true,
  "description": "Vortex - A Event-Driven E-Commerce Ecosystem",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --check . --ignore-path .prettierignore && turbo format",
    "format:fix": "prettier --write . --ignore-path .prettierignore && turbo format:fix",
    "ci:fix": "pnpm lint:fix && pnpm format:fix",
    "ci:check": "pnpm lint && pnpm format && pnpm typecheck",
    "clean": "turbo clean && rimraf node_modules",
    "clean:turbo": "turbo clean:turbo && rimraf .turbo node_modules",
    "prepare": "husky",
    "commit": "cz",
    "auth:dev": "pnpm --filter=auth-service dev",
    "auth:seed": "pnpm --filter=auth-service seed",
    "auth:build": "pnpm --filter=auth-service... build",
    "order:dev": "pnpm --filter=order-service dev",
    "order:build": "pnpm --filter=order-service... build",
    "product:dev": "pnpm --filter=product-service dev",
    "product:build": "pnpm --filter=product-service... build",
    "notification:dev": "pnpm --filter=notification-service dev",
    "notification:build": "pnpm --filter=notification-service... build",
    "activity:dev": "pnpm --filter=activity-service dev",
    "activity:build": "pnpm --filter=activity-service... build",
    "payment:dev": "pnpm --filter=payment-service dev",
    "payment:build": "pnpm --filter=payment-service... build",
    "gateway:dev": "pnpm --filter=gateway dev",
    "gateway:build": "pnpm --filter=gateway... build",
    "analytics:dev": "pnpm --filter=analytics-service dev",
    "analytics:build": "pnpm --filter=analytics-service... build",
    "web:dev": "pnpm --filter=@vortex/web dev",
    "web:build": "pnpm --filter=@vortex/web build",
    "web:preview": "pnpm --filter=@vortex/web preview",
    "release": "semantic-release"
  },
  "workspaces": [
    "common",
    "services/*",
    "gateway",
    "web"
  ],
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "keywords": [],
  "author": "https://github.com/shahadathhs",
  "license": "ISC",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@systemix/eslint": "^0.4.0",
    "@systemix/typescript": "^0.4.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    }
  }
}
