{
  "name": "@vortex/gateway",
  "version": "1.0.0",
  "description": "API Gateway for Vortex ecosystem",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check . --ignore-path .prettierignore",
    "format:fix": "prettier --write . --ignore-path .prettierignore",
    "clean": "rimraf dist node_modules",
    "clean:turbo": "rimraf .turbo dist node_modules"
  },
  "dependencies": {
    "@vortex/common": "workspace:*",
    "cors": "catalog:",
    "express": "catalog:",
    "helmet": "catalog:",
    "express-rate-limit": "catalog:",
    "http-proxy-middleware": "^3.0.5",
    "@systemix/env": "catalog:",
    "swagger-ui-express": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "catalog:",
    "@types/swagger-ui-express": "catalog:",
    "@types/express": "catalog:",
    "rimraf": "catalog:",
    "ts-node-dev": "catalog:",
    "typescript": "catalog:"
  }
}
